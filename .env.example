MQTT_BROKER_URL=tls://localhost:8883
MQTT_USERNAME=iot
MQTT_PASSWORD=changeme
# CA, которым подписан сертификат брокера (см. deploy/mosquitto/gen-dev-certs.sh) —
# самоподписанный, системный пул доверенных корней его не примет.
MQTT_CA_CERT_FILE=./deploy/mosquitto/certs/ca.crt

DATABASE_URL=postgres://iot:changeme@localhost:5432/iot?sslmode=disable

HTTP_ADDR=:8080
