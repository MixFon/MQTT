# Reverse proxy для REST API и веб-дашборда.
# Go-сервер слушает только 127.0.0.1:8080 (см. iot-backend.env.example),
# наружу смотрит только Caddy — он же берёт на себя TLS через Let's Encrypt.
#
# mrmixfon.ru сейчас настроен на другую машину, поэтому используется
# поддомен — для него нужна отдельная A-запись, указывающая на этот VPS.
iot.mrmixfon.ru {
	reverse_proxy 127.0.0.1:8080
}
