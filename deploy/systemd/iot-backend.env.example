# Шаблон переменных окружения для systemd-юнита (Этап 6).
#
# На VPS: скопировать в /etc/iot-backend.env, заполнить реальными значениями,
# затем ограничить доступ:
#   sudo chown root:iot-backend /etc/iot-backend.env
#   sudo chmod 640 /etc/iot-backend.env
#
# В отличие от .env.example в корне репозитория (для локальной разработки
# через docker-compose), этот файл живёт только на сервере — сам он
# с реальными секретами в репозиторий не попадает.

MQTT_BROKER_URL=tls://localhost:8883
MQTT_USERNAME=iot
MQTT_PASSWORD=changeme

DATABASE_URL=postgres://iot:changeme@localhost:5432/iot?sslmode=disable

# Слушаем только localhost — наружу смотрит Caddy (см. deploy/Caddyfile),
# сам Go-процесс наружу не торчит.
HTTP_ADDR=127.0.0.1:8080
